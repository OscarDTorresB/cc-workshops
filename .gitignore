# Python .gitignore

# Byte-compiled / optimized / cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment files (keep .env.example tracked)
.env
.env.local

# Streamlit secrets
.streamlit/secrets.toml

# Test / type-checker / linter caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Packaging / build artifacts
*.egg-info/
dist/
build/

# OS files
.DS_Store
